<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>false</ImplicitUsings>
        <IsPackable>false</IsPackable>
        <!-- Disable code analysis for test entities -->
        <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
        <EnableNETAnalyzers>false</EnableNETAnalyzers>
        <AnalysisMode>None</AnalysisMode>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <!-- Dev-only netstandard2.0 generator: don't run SDK code-style / NetAnalyzers here.
             They're version-locked to the building SDK's Roslyn and cause CS9057 when this
             project is built by an older compiler band (e.g. csc 5.3 vs analyzers built for 5.6). -->
        <RunAnalyzers>false</RunAnalyzers>
        <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
        <NoWarn>$(NoWarn);CS1591;SA1600</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <AssemblyAttribute Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage"/>
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\DKNet.EfCore.Abstractions\DKNet.EfCore.Abstractions.csproj"/>
    </ItemGroup>

</Project>
